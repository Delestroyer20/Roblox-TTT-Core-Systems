local function getFlatDirection(vector, fallback)
	local flattened = Vector3.new(vector.X, 0, vector.Z)
	if flattened.Magnitude > 0.001 then
		return flattened.Unit
	end

	local fallbackDirection = fallback or Vector3.new(0, 0, -1)
	local fallbackFlat = Vector3.new(fallbackDirection.X, 0, fallbackDirection.Z)
	if fallbackFlat.Magnitude > 0.001 then
		return fallbackFlat.Unit
	end

	return Vector3.new(0, 0, -1)
end

local function setCharacterAnchored(character, anchored)
	if character:IsA("BasePart") then
		character.Anchored = anchored
		character.CanCollide = false
		character.CanTouch = false

		if anchored then
			character.AssemblyLinearVelocity = Vector3.zero
			character.AssemblyAngularVelocity = Vector3.zero
		end
	end

	for _, descendant in character:GetDescendants() do
		if descendant:IsA("BasePart") then
			descendant.Anchored = anchored
			descendant.CanCollide = false
			descendant.CanTouch = false

			if anchored then
				descendant.AssemblyLinearVelocity = Vector3.zero
				descendant.AssemblyAngularVelocity = Vector3.zero
			end
		end
	end
end

local function markInstanceAsCorpse(corpseInstance, player)
	local brainrotId = getEffectiveBrainrotId(player)
	local brainrotConfig = brainrotId and BRAINROTS[brainrotId] or nil
	local corpseRole = playerRoles[player] or "Unknown"
	local corpseTeam = if corpseRole == "Traitor" then "Traitor" else "Innocent"

	corpseInstance:SetAttribute("TTTCorpse", true)
	corpseInstance:SetAttribute("CorpsePlayerName", player.Name)
	corpseInstance:SetAttribute("CorpseUserId", player.UserId)
	corpseInstance:SetAttribute("CorpseRole", corpseRole)
	corpseInstance:SetAttribute("CorpseTeam", corpseTeam)
	corpseInstance:SetAttribute("CorpseBrainrotId", brainrotId or "")
	corpseInstance:SetAttribute("CorpseBrainrotName", brainrotConfig and brainrotConfig.displayName or "")
	corpseInstance:SetAttribute("CorpseCreatedAt", os.time())
	corpseInstance:SetAttribute("CorpseIdentified", false)
end

local function cloneCorpseAsset(asset)
	local corpseClone

	if asset:IsA("Model") then
		corpseClone = asset:Clone()
	elseif asset:IsA("Folder") then
		corpseClone = Instance.new("Model")
		corpseClone.Name = asset.Name

		for _, child in asset:GetChildren() do
			child:Clone().Parent = corpseClone
		end
	else
		corpseClone = asset:Clone()
	end

	for _, descendant in corpseClone:GetDescendants() do
		if descendant:IsA("Script") or descendant:IsA("LocalScript") or descendant:IsA("ModuleScript") then
			descendant:Destroy()
		end
	end

	return corpseClone
end

local function getCorpsePrimaryPart(corpseInstance)
	if corpseInstance:IsA("BasePart") then
		return corpseInstance
	end

	if corpseInstance:IsA("Model") then
		if corpseInstance.PrimaryPart then
			return corpseInstance.PrimaryPart
		end

		local primaryPart = corpseInstance:FindFirstChildWhichIsA("BasePart", true)
		if primaryPart then
			corpseInstance.PrimaryPart = primaryPart
		end

		return primaryPart
	end

	return corpseInstance:FindFirstChildWhichIsA("BasePart", true)
end

local function getInstanceBoundingSize(instance)
	if instance:IsA("BasePart") then
		return instance.Size
	end

	local _, boxSize = instance:GetBoundingBox()
	return boxSize
end

local function getCorpseTargetCFrame(corpseInstance, originCFrame, raycastIgnoreList, layAngle)
	local rootPosition = originCFrame.Position
	local facingDirection = getFlatDirection(originCFrame.LookVector)
	local boxSize = getInstanceBoundingSize(corpseInstance)
	local corpseThickness = math.max(math.min(boxSize.X, boxSize.Z), 0.8)

	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.FilterDescendantsInstances = raycastIgnoreList or { corpseInstance }

	local groundResult = Workspace:Raycast(rootPosition + Vector3.new(0, 8, 0), Vector3.new(0, -40, 0), raycastParams)
	local targetY

	if groundResult then
		targetY = groundResult.Position.Y + (corpseThickness * 0.5) + CORPSE_GROUND_CLEARANCE
	else
		targetY = rootPosition.Y - math.clamp(boxSize.Y * 0.35, 1.5, 4)
	end

	local targetPosition = Vector3.new(rootPosition.X, targetY, rootPosition.Z) + (facingDirection * 0.35)
	return CFrame.lookAt(targetPosition, targetPosition + facingDirection) * CFrame.Angles(0, 0, layAngle or 0)
end

local function animateCorpseFall(corpseInstance, startCFrame, targetCFrame)
	task.spawn(function()
		local startTime = time()

		while corpseInstance.Parent do
			local alpha = math.clamp((time() - startTime) / CORPSE_FALL_DURATION, 0, 1)
			local easedAlpha = 1 - ((1 - alpha) * (1 - alpha) * (1 - alpha))

			corpseInstance:PivotTo(startCFrame:Lerp(targetCFrame, easedAlpha))

			if alpha >= 1 then
				break
			end

			RunService.Heartbeat:Wait()
		end

		if corpseInstance.Parent then
			corpseInstance:PivotTo(targetCFrame)
		end
	end)
end

