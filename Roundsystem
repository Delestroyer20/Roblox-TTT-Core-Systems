		return true
	end

	return instance.Name == "READ ME"
		or instance.Name == "ThumbnailCamera"
end

local function findWeaponVisualAsset(definition)
	local weaponAssetsFolder = ServerStorage:FindFirstChild(WEAPON_ASSETS_FOLDER_NAME)

	local assetNames = {}
	local seenAssetNames = {}

	local function appendAssetName(assetName)
		if typeof(assetName) ~= "string" or assetName == "" or seenAssetNames[assetName] then
			return
		end

		seenAssetNames[assetName] = true
		table.insert(assetNames, assetName)
	end

	appendAssetName(definition.toolName)
	if typeof(definition.visualAssetName) == "string" and definition.visualAssetName ~= "" then
		appendAssetName(definition.visualAssetName)
	end
	if typeof(definition.visualAssetNames) == "table" then
		for _, assetName in ipairs(definition.visualAssetNames) do
			appendAssetName(assetName)
		end
	end

	for _, assetName in ipairs(assetNames) do
		local asset = weaponAssetsFolder and weaponAssetsFolder:FindFirstChild(assetName, true)
		if not asset then
			asset = ServerStorage:FindFirstChild(assetName, true)
		end
		if asset then
			return asset
		end
	end

	return nil
end

local function markGeneratedWeaponVisual(instance)
	if not instance then
		return
	end

	instance:SetAttribute("TTTGeneratedWeaponVisual", true)
	for _, descendant in ipairs(instance:GetDescendants()) do
		descendant:SetAttribute("TTTGeneratedWeaponVisual", true)
	end
end

local function clearGeneratedWeaponVisual(tool)
	for _, child in ipairs(tool:GetChildren()) do
		if child:GetAttribute("TTTGeneratedWeaponVisual") then
			child:Destroy()
		end
	end
end

local function prepareWeaponVisualPart(part)
	if not part or not part:IsA("BasePart") then
		return
	end

	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.Massless = true
	part.CastShadow = false
	part.Anchored = false
end

local function attachWeaponVisual(tool, definition)
	clearGeneratedWeaponVisual(tool)

	local asset = findWeaponVisualAsset(definition)
	if not asset then
		return
	end

	if asset:IsA("Tool") then
		local handleClone = nil
		tool.TextureId = asset.TextureId

		for _, child in ipairs(asset:GetChildren()) do
			if isIgnoredWeaponAssetChild(child) then
				continue
			end

			local clone = child:Clone()
			if clone:IsA("BasePart") then
				prepareWeaponVisualPart(clone)
			end

			clone.Parent = tool
			markGeneratedWeaponVisual(clone)

			if clone.Name == "Handle" and clone:IsA("BasePart") then
				handleClone = clone
			end
		end

		if handleClone then
			for _, descendant in ipairs(tool:GetDescendants()) do
				if descendant:IsA("BasePart")
					and descendant ~= handleClone
					and descendant:GetAttribute("TTTGeneratedWeaponVisual")
				then
					prepareWeaponVisualPart(descendant)

					local weld = Instance.new("WeldConstraint")
					weld.Part0 = handleClone
					weld.Part1 = descendant
					weld.Parent = descendant
					markGeneratedWeaponVisual(weld)
				end
			end

			tool.Grip = asset.Grip
		end

		return
	end

	if asset:IsA("BasePart") then
		local handle = asset:Clone()
		handle.Name = "Handle"
		prepareWeaponVisualPart(handle)
		handle.Transparency = asset.Transparency
		handle.Parent = tool
		markGeneratedWeaponVisual(handle)
		return
	end

	local visualClone = asset:Clone()
	local referencePart = visualClone:IsA("Model")
		and (visualClone.PrimaryPart or visualClone:FindFirstChildWhichIsA("BasePart", true))
		or visualClone:FindFirstChildWhichIsA("BasePart", true)

	if not referencePart then
		visualClone:Destroy()
		return
	end

	visualClone.Name = definition.visualAssetName
	visualClone.Parent = tool
	markGeneratedWeaponVisual(visualClone)

	local handle = Instance.new("Part")
	handle.Name = "Handle"
	handle.Size = Vector3.new(
		math.max(referencePart.Size.X, 0.2),
		math.max(referencePart.Size.Y, 0.2),
		math.max(referencePart.Size.Z, 0.2)
	)
	handle.CFrame = referencePart.CFrame
	handle.Transparency = 1
	prepareWeaponVisualPart(handle)
	handle.Parent = tool
	markGeneratedWeaponVisual(handle)

	for _, descendant in ipairs(visualClone:GetDescendants()) do
		if descendant:IsA("BasePart") then
			prepareWeaponVisualPart(descendant)

			local weld = Instance.new("WeldConstraint")
			weld.Part0 = handle
			weld.Part1 = descendant
			weld.Parent = descendant
			markGeneratedWeaponVisual(weld)
		end
	end
end

local function weaponPrototypeHasEmbeddedScripts(tool)
	return tool
		and tool:IsA("Tool")
		and (
			tool:FindFirstChildWhichIsA("LocalScript", true) ~= nil
			or tool:FindFirstChildWhichIsA("Script", true) ~= nil
		)
end

local function configureWeaponPrototype(tool, definition)
	local usesEmbeddedScripts = weaponPrototypeHasEmbeddedScripts(tool)
	local hasHandle = tool:FindFirstChild("Handle") ~= nil

	tool.Name = definition.toolName
	tool.RequiresHandle = hasHandle
	tool.CanBeDropped = false
	tool.ManualActivationOnly = false
	tool.ToolTip = definition.displayName
	tool:SetAttribute("TTTWeaponPrototype", true)
	tool:SetAttribute("TTTWeaponId", definition.weaponId)
	tool:SetAttribute("TTTDisplayName", definition.displayName)
	tool:SetAttribute("TTTForceFirstPerson", definition.forceFirstPerson == true)
	tool:SetAttribute("TTTUsesEmbeddedScripts", usesEmbeddedScripts)

	tool:SetAttribute("TTTClipSize", definition.clipSize)
	tool:SetAttribute("TTTAmmoInMagazine", definition.clipSize)
	tool:SetAttribute("TTTIsReloading", false)
end

local function ensureWeaponPrototypes()
	for _, definition in pairs(WEAPON_DEFINITIONS) do
		local existingTool = ServerStorage:FindFirstChild(definition.toolName)
		if existingTool and not existingTool:IsA("Tool") then
			existingTool:Destroy()
			existingTool = nil
		end

		if existingTool
			and definition.forceGeneratedPrototype
			and not weaponPrototypeHasEmbeddedScripts(existingTool)
		then
			-- Only replace plain/generated prototypes; scripted tools are preserved intact.
			existingTool:Destroy()
			existingTool = nil
		end

		if not existingTool then
			local asset = findWeaponVisualAsset(definition)
			if asset and asset:IsA("Tool") then
				existingTool = asset:Clone()
			else
				existingTool = Instance.new("Tool")
				attachWeaponVisual(existingTool, definition)
			end

			existingTool.Parent = ServerStorage
		end

		configureWeaponPrototype(existingTool, definition)
	end
end

local function initializeWeaponInstance(tool)
	local definition = getWeaponDefinitionByTool(tool)
	if not definition then
		return
	end

	configureWeaponPrototype(tool, definition)
	disconnectWeaponState(tool)

	local state = {
		definition = definition,
		ammo = definition.clipSize,
		isReloading = false,
		lastFireAt = 0,
	}

	weaponStates[tool] = state
	syncWeaponAttributes(tool, state)

	weaponConnections[tool] = {
		tool.Destroying:Connect(function()
			disconnectWeaponState(tool)
		end),
	}
end

local function getToolOwner(tool)
	if not tool or not tool:IsA("Tool") then
		return nil
	end

	local parent = tool.Parent
	if not parent then
		return nil
	end

	if parent:IsA("Backpack") and parent.Parent and parent.Parent:IsA("Player") then
		return parent.Parent
	end

	if parent:IsA("Model") then
		return Players:GetPlayerFromCharacter(parent)
	end

	return nil
end

local function getLiveHumanoid(player)
	if not player or deadPlayers[player] then
		return nil
	end

	local character = player.Character
	if not character then
		return nil
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid or humanoid.Health <= 0 then
		return nil
	end

	return humanoid
end

local function findHumanoidFromInstance(instance)
	local current = instance
	while current do
		if current:IsA("Model") then
			local humanoid = current:FindFirstChildOfClass("Humanoid")
			if humanoid then
				return humanoid
			end
		end

		current = current.Parent
	end

	return nil
end

local function beginWeaponReload(player, tool, state)
	if not player or not tool or not state then
		return
	end

	if state.isReloading or state.ammo >= state.definition.clipSize then
		return
	end

	state.isReloading = true
	syncWeaponAttributes(tool, state)

	task.delay(state.definition.reloadTime, function()
		if weaponStates[tool] ~= state then
			return
		end

		if getToolOwner(tool) ~= player then
			return
		end

		state.isReloading = false
		state.ammo = state.definition.clipSize
		syncWeaponAttributes(tool, state)
	end)
end

