local function createFallbackLocalization()
	local values = {
		["common.random"] = "Random",
		["common.unknown"] = "Unknown",
		["role.alignment.traitor"] = "a Traitor",
		["role.alignment.innocent"] = "an Innocent",
		["corpse.promptAction"] = "Identify",
		["corpse.promptObject"] = "Corpse",
		["corpse.identified"] = "{playerName} was {alignment}!",
		["round.waitingForPlayers"] = "Waiting for players... ({playerCount}/{minPlayers})",
		["round.tooManyPlayers"] = "Too many players for a round ({playerCount}/{maxPlayers})",
		["round.nextRoundIn"] = "Next round in",
		["round.started"] = "Round started!",
		["round.inProgress"] = "Round in progress",
		["round.ending.innocentsWin"] = "Innocents win!",
		["round.ending.traitorsWin"] = "Traitors win!",
		["brainrot.messages.chooseForNextRound"] = "Choose your Brainrot for the next round.",
		["brainrot.messages.selectionLockedDuringRound"] = "Selection is locked during the round.",
		["brainrot.messages.unknown"] = "Unknown Brainrot.",
		["brainrot.messages.selected"] = "Selected: {name}",
		["brainrot.messages.roundStarting"] = "Selection locked. Round starting.",
		["brainrot.options.TralaleroTralala.description"] = "Fast. Loud. Runner.",
		["brainrot.options.TralaleroTralala.bonus"] = "Sprint faster!",
		["brainrot.options.BombardiroCrocodilo.description"] = "Chaotic. Tough. Heavy.",
		["brainrot.options.BombardiroCrocodilo.bonus"] = "More health!",
		["brainrot.options.TungTungTungSahur.description"] = "Alarm. Jump. All-rounder.",
		["brainrot.options.TungTungTungSahur.bonus"] = "Jump higher!",
	}

	return {
		getText = function(_, key, params)
			local template = values[key] or key
			if not params then
				return template
			end

			return string.gsub(template, "{([%w_]+)}", function(token)
				local value = params[token]
				if value == nil then
					return "{" .. token .. "}"
				end

				return tostring(value)
			end)
		end,
	}
end

