local function getTeleportablePlayers()
	local teleportablePlayers = {}

	for _, player in Players:GetPlayers() do
		if player.Parent == Players then
			table.insert(teleportablePlayers, player)
		end
	end

	return teleportablePlayers
end

local function isSoloReturnTest()
	return DEBUG_SOLO_RETURN_TEST_ENABLED and #Players:GetPlayers() == 1
end

local function returnPlayersToLobby()
	if RunService:IsStudio() then
		warn("Rueckkehr zur Lobby wird in Studio uebersprungen. Verwende den Roblox Player fuer echte Teleport-Tests.")
		return false
	end

	if LOBBY_PLACE_ID <= 0 then
		warn("LOBBY_PLACE_ID ist ungueltig. Spieler bleiben nach dem Match im MatchPlace.")
		return false
	end

	local teleportablePlayers = getTeleportablePlayers()
	if #teleportablePlayers == 0 then
		return true
	end

	local teleportOptions = Instance.new("TeleportOptions")
	teleportOptions:SetTeleportData({
		returnedFromMatch = true,
		winner = roundWinner,
		returnedAt = os.time(),
	})

	local success, result = pcall(function()
		return TeleportService:TeleportAsync(LOBBY_PLACE_ID, teleportablePlayers, teleportOptions)
	end)

	if not success then
		warn("Rueckkehr zur Lobby fehlgeschlagen: " .. tostring(result))
		return false
	end

	return true
end

