local function getCorpseDisplayName(corpseInstance)
	return corpseInstance:GetAttribute("CorpsePlayerName")
end

local function getCorpseAlignmentLabel(corpseInstance)
	local corpseTeam = corpseInstance:GetAttribute("CorpseTeam")
	if corpseTeam == "Traitor" then
		return "Traitor"
	end

	return "Innocent"
end

local function getAlignmentTranslationKey(alignment)
	if alignment == "Traitor" then
		return "role.alignment.traitor"
	end

	return "role.alignment.innocent"
end

local function attachCorpseIdentifyPrompt(corpseInstance)
	local promptParent = getCorpsePrimaryPart(corpseInstance)
	if not promptParent then
		return
	end

	local existingPrompt = promptParent:FindFirstChild("CorpseIdentifyPrompt")
	if existingPrompt and existingPrompt:IsA("ProximityPrompt") then
		return
	end

	local prompt = Instance.new("ProximityPrompt")
	prompt.Name = "CorpseIdentifyPrompt"
	prompt.ActionText = t("en", "corpse.promptAction")
	prompt.ObjectText = t("en", "corpse.promptObject")
	prompt.KeyboardKeyCode = CORPSE_IDENTIFY_KEY
	prompt.MaxActivationDistance = CORPSE_IDENTIFY_DISTANCE
	prompt.HoldDuration = CORPSE_IDENTIFY_HOLD_DURATION
	prompt.RequiresLineOfSight = false
	prompt.Style = Enum.ProximityPromptStyle.Default
	prompt.Parent = promptParent

	prompt.Triggered:Connect(function(triggeringPlayer)
		if not roundActive then
			return
		end

		if playerRoles[triggeringPlayer] ~= "Detective" then
			return
		end

		if corpseInstance:GetAttribute("CorpseIdentified") then
			return
		end

		corpseInstance:SetAttribute("CorpseIdentified", true)
		prompt.Enabled = false

		local identifiedPlayerName = getCorpseDisplayName(corpseInstance)
		local identifiedAlignment = getCorpseAlignmentLabel(corpseInstance)
		broadcastLocalized("corpseIdentified", {
			playerName = identifiedPlayerName,
			alignment = identifiedAlignment,
			role = corpseInstance:GetAttribute("CorpseRole") or identifiedAlignment,
			identifiedBy = triggeringPlayer.Name,
		}, "corpse.identified", function(player)
			return {
				playerName = identifiedPlayerName or t(player, "common.unknown"),
				alignment = t(player, getAlignmentTranslationKey(identifiedAlignment)),
			}
		end)

		task.delay(CORPSE_IDENTIFIED_DESPAWN_DELAY, function()
			if corpseInstance and corpseInstance.Parent then
				corpseInstance:Destroy()
			end
		end)
	end)
end

local function spawnSharedCorpse(player, character, startCFrame)
	local corpseAsset = corpseAssetsFolder:FindFirstChild(SHARED_CORPSE_ASSET_NAME)
	if not corpseAsset then
		return nil
	end

	local corpseClone = cloneCorpseAsset(corpseAsset)
	local corpsePrimaryPart = getCorpsePrimaryPart(corpseClone)
	if not corpsePrimaryPart then
		corpseClone:Destroy()
		return nil
	end

	corpseClone.Name = "Corpse_" .. player.Name
	corpseClone.Parent = Workspace
	corpseClone:PivotTo(startCFrame)

	setCharacterAnchored(corpseClone, true)
	markInstanceAsCorpse(corpseClone, player)
	attachCorpseIdentifyPrompt(corpseClone)
	table.insert(spawnedCorpses, corpseClone)

	local targetCFrame = getCorpseTargetCFrame(corpseClone, startCFrame, { character, corpseClone }, 0)
	animateCorpseFall(corpseClone, startCFrame, targetCFrame)

	return corpseClone
end

local function preserveCorpse(player, character)
	if not character or character.Parent == nil then
		return
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not humanoid or not rootPart then
		return
	end

	disconnectVisualAnimation(character)
	clearGrantedTools(player)
	clearBrainrotHitboxes(character)

	humanoid.AutoRotate = false
	if humanoid.RootPart then
		humanoid.RootPart.AssemblyLinearVelocity = Vector3.zero
		humanoid.RootPart.AssemblyAngularVelocity = Vector3.zero
	end

	local startCFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + getFlatDirection(rootPart.CFrame.LookVector))
	local sharedCorpse = spawnSharedCorpse(player, character, startCFrame)
	if sharedCorpse then
		task.defer(function()
			if character.Parent then
				character:Destroy()
			end
		end)
		return
	end

	markInstanceAsCorpse(character, player)
	character.PrimaryPart = rootPart
	attachCorpseIdentifyPrompt(character)
	local targetCFrame = getCorpseTargetCFrame(character, startCFrame, { character }, CORPSE_FALL_ANGLE)

	setCharacterAnchored(character, true)
	character:PivotTo(startCFrame)
	animateCorpseFall(character, startCFrame, targetCFrame)
end

local function isBrainrotAppliedInstance(instance)
	local current = instance

	while current do
		if current:GetAttribute("BrainrotApplied") then
			return true
		end

		current = current.Parent
	end

	return false
end

local function hideBaseCharacter(character, shouldHide)
	for _, descendant in character:GetDescendants() do
		if isBrainrotAppliedInstance(descendant) then
			continue
		end

		if descendant:IsA("BasePart") and descendant.Name ~= "HumanoidRootPart" then
			if shouldHide then
				if descendant:GetAttribute("BrainrotOriginalTransparency") == nil then
					descendant:SetAttribute("BrainrotOriginalTransparency", descendant.Transparency)
				end
				if descendant:GetAttribute("BrainrotOriginalCanQuery") == nil then
					descendant:SetAttribute("BrainrotOriginalCanQuery", descendant.CanQuery)
				end
				descendant.Transparency = 1
				descendant.CanQuery = false
			else
				local originalTransparency = descendant:GetAttribute("BrainrotOriginalTransparency")
				local originalCanQuery = descendant:GetAttribute("BrainrotOriginalCanQuery")
				if originalTransparency ~= nil then
					descendant.Transparency = originalTransparency
					descendant:SetAttribute("BrainrotOriginalTransparency", nil)
				end
				if originalCanQuery ~= nil then
					descendant.CanQuery = originalCanQuery
					descendant:SetAttribute("BrainrotOriginalCanQuery", nil)
				end
			end
		elseif descendant:IsA("Decal") then
			if shouldHide then
				if descendant:GetAttribute("BrainrotOriginalTransparency") == nil then
					descendant:SetAttribute("BrainrotOriginalTransparency", descendant.Transparency)
				end
				descendant.Transparency = 1
			else
				local originalTransparency = descendant:GetAttribute("BrainrotOriginalTransparency")
				if originalTransparency ~= nil then
					descendant.Transparency = originalTransparency
					descendant:SetAttribute("BrainrotOriginalTransparency", nil)
				end
			end
		end
	end
end

