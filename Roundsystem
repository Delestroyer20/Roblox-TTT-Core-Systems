local function t(target, key, params)
	return RoundLocalization.getText(target, key, params)
end

local function cloneMap(source)
	local clone = {}

	if not source then
		return clone
	end

	for key, value in pairs(source) do
		clone[key] = value
	end

	return clone
end

local function resolveMessageParams(player, messageParams)
	if type(messageParams) == "function" then
		return messageParams(player)
	end

	return messageParams
end

local function fireRoundEvent(player, state, data, messageKey, messageParams)
	local payload = cloneMap(data)

	if messageKey then
		payload.message = t(player, messageKey, resolveMessageParams(player, messageParams))
	end

	player:SetAttribute("TTTRoundState", state)

	RoundEvent:FireClient(player, state, payload)
end

local function broadcastLocalized(state, data, messageKey, messageParams)
	for _, player in Players:GetPlayers() do
		fireRoundEvent(player, state, data, messageKey, messageParams)
	end
end

local function getRandomBrainrotId()
	local brainrotIds = {}

	for brainrotId in BRAINROTS do
