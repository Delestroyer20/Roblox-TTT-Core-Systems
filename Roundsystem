local function configureBrainrotQueryPart(part)
	if not part or not part:IsA("BasePart") then
		return
	end

	if part.Name:match("^HB_") ~= nil and part:FindFirstAncestor("Hitboxes") ~= nil then
		part.Transparency = 1
		part.CanQuery = false
		part.CanTouch = false
		part.CanCollide = false
		return
	end

	part:SetAttribute("BrainrotHitbox", nil)
	local shouldQueryPart = part.Name ~= "BrainrotVisualRoot" and part.Transparency < 0.99
	part.CanQuery = shouldQueryPart

	if shouldQueryPart and part:IsA("MeshPart") then
		pcall(function()
			part.CollisionFidelity = Enum.CollisionFidelity.PreciseConvexDecomposition
		end)
	end
end

local function createBrainrotHitboxes(character, brainrotId)
	clearBrainrotHitboxes(character)

	for _, descendant in character:GetDescendants() do
		if not descendant:IsA("BasePart") then
			continue
		end

		if isBrainrotAppliedInstance(descendant) then
			configureBrainrotQueryPart(descendant)
		end
	end
end

local function collectWearables(asset)
	local wearables = {}

	local function collectWearable(instance)
		if instance:IsA("Accessory")
			or instance:IsA("Shirt")
			or instance:IsA("Pants")
			or instance:IsA("BodyColors")
			or instance:IsA("ShirtGraphic")
			or instance:IsA("CharacterMesh")
		then
			table.insert(wearables, instance)
		end
	end

	collectWearable(asset)

	for _, descendant in asset:GetDescendants() do
		collectWearable(descendant)
	end

	return wearables
end

local function applyWearablesToModel(character, asset, markAsApplied)
	local wearablesFound = false
	local wearablesToClone = collectWearables(asset)
	local humanoid = character:FindFirstChildOfClass("Humanoid")

	for _, wearable in wearablesToClone do
		if wearable:IsA("Shirt") then
			for _, child in character:GetChildren() do
				if child:IsA("Shirt") then
					child:Destroy()
				end
			end
		elseif wearable:IsA("Pants") then
			for _, child in character:GetChildren() do
				if child:IsA("Pants") then
					child:Destroy()
				end
			end
		elseif wearable:IsA("BodyColors") then
			for _, child in character:GetChildren() do
				if child:IsA("BodyColors") then
					child:Destroy()
				end
			end
		end

		local clone = wearable:Clone()
		if markAsApplied then
			clone:SetAttribute("BrainrotApplied", true)
		end

		if clone:IsA("Accessory") and humanoid then
			local success = pcall(function()
				humanoid:AddAccessory(clone)
			end)

			if not success then
				clone.Parent = character
			end
		else
			clone.Parent = character
		end

		for _, descendant in clone:GetDescendants() do
			if descendant:IsA("BasePart") then
				configureBrainrotQueryPart(descendant)
			end
		end

		wearablesFound = true
	end

	return wearablesFound
end

local function cloneWearables(character, asset)
	return applyWearablesToModel(character, asset, true)
end

local function stripScripts(container)
	for _, descendant in container:GetDescendants() do
		if descendant:IsA("Script") or descendant:IsA("LocalScript") or descendant:IsA("ModuleScript") then
			descendant:Destroy()
		end
	end
end

local function buildVisualModel(asset)
	local visualModel

	if asset:IsA("Model") then
		visualModel = asset:Clone()
	elseif asset:IsA("Folder") then
		visualModel = Instance.new("Model")
		visualModel.Name = asset.Name

		for _, child in asset:GetChildren() do
			child:Clone().Parent = visualModel
		end
	else
		visualModel = Instance.new("Model")
		visualModel.Name = asset.Name
		asset:Clone().Parent = visualModel
	end

	stripScripts(visualModel)
	visualModel:SetAttribute("BrainrotApplied", true)
	return visualModel
end

local function scaleModelIfNeeded(model, scale)
	if not scale or scale == 1 then
		return
	end

	pcall(function()
		model:ScaleTo(scale)
	end)
end

local function getLargestBoundingAxis(model)
	local _, boxSize = model:GetBoundingBox()
	return math.max(boxSize.X, boxSize.Y, boxSize.Z, 0.001)
end

local function resolveAssetScale(asset, config)
	if not config then
		return nil
	end

	if config.assetScale then
		return config.assetScale
	end

	if not config.matchVisualScaleOf then
		return nil
	end

	local cacheKey = config.assetName
	if cacheKey and resolvedAssetScales[cacheKey] then
		return resolvedAssetScales[cacheKey]
	end

	local referenceConfig = BRAINROTS[config.matchVisualScaleOf]
	if not referenceConfig then
		return nil
	end

	local referenceAsset = brainrotAssetsFolder:FindFirstChild(referenceConfig.assetName)
	if not referenceAsset then
		return nil
	end

	local sourceModel = buildVisualModel(asset)
	local referenceModel = buildVisualModel(referenceAsset)
	local sourceLargestAxis = getLargestBoundingAxis(sourceModel)
	local referenceLargestAxis = getLargestBoundingAxis(referenceModel)
	sourceModel:Destroy()
	referenceModel:Destroy()

	if sourceLargestAxis <= 0 or referenceLargestAxis <= 0 then
		return nil
	end

	local referenceScale = referenceConfig.assetScale or 1
	local resolvedScale = (referenceLargestAxis * referenceScale) / sourceLargestAxis

	if cacheKey then
		resolvedAssetScales[cacheKey] = resolvedScale
	end

	return resolvedScale
end

local function applyConfiguredPartOffsets(container, partOffsets)
	if not partOffsets then
		return
	end

	for _, descendant in container:GetDescendants() do
		if descendant:IsA("BasePart") then
			local offset = partOffsets[descendant.Name]
			if offset then
				descendant.Position = descendant.Position + offset
			end
		end
	end
end

local function createVisualMotionRoot(character, rootPart, baseOffset)
	local motionRoot = Instance.new("Part")
	motionRoot.Name = "BrainrotVisualRoot"
	motionRoot.Size = Vector3.new(1, 1, 1)
	motionRoot.Transparency = 1
	motionRoot.CanCollide = false
	motionRoot.CanTouch = false
	motionRoot.CanQuery = false
	motionRoot.Massless = true
	motionRoot.CastShadow = false
	motionRoot.Anchored = false
	motionRoot.CFrame = rootPart.CFrame * baseOffset
	motionRoot:SetAttribute("BrainrotApplied", true)
	motionRoot.Parent = character

	local weld = Instance.new("Weld")
	weld.Name = "BrainrotVisualMotionWeld"
	weld.Part0 = rootPart
	weld.Part1 = motionRoot
	weld.C0 = baseOffset
	weld.Parent = motionRoot

	return motionRoot, weld
end

local function startVisualMotion(character, rootPart, motionWeld, config)
	if not config or config.visualMotionStyle ~= "GoofyWalk" then
		return
	end

	disconnectVisualAnimation(character)

	local baseOffset = config.assetOffset or CFrame.new()
	local startTime = time()

	visualAnimationConnections[character] = RunService.Heartbeat:Connect(function()
		if character.Parent == nil or rootPart.Parent == nil or motionWeld.Parent == nil then
			disconnectVisualAnimation(character)
			return
		end

		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if not humanoid then
			return
		end

		local elapsed = time() - startTime
		local horizontalVelocity = Vector3.new(rootPart.AssemblyLinearVelocity.X, 0, rootPart.AssemblyLinearVelocity.Z).Magnitude
		local moveBlend = math.clamp(horizontalVelocity / math.max(humanoid.WalkSpeed, 1), 0, 1.35)
		local isMoving = humanoid.MoveDirection.Magnitude > 0.05 and moveBlend > 0.08
		local animationOffset

		if isMoving then
			local walkSpeed = 8 + (moveBlend * 8)
			local stepWave = math.sin(elapsed * walkSpeed)
			local swayWave = math.sin(elapsed * (walkSpeed * 0.5))
			local bounce = math.abs(stepWave) * (0.22 + moveBlend * 0.08)
			local sideShift = swayWave * (0.12 + moveBlend * 0.04)
			local pitch = math.rad(-6) * math.abs(stepWave)
			local yaw = math.rad(4) * swayWave
			local roll = math.rad(10) * stepWave

			animationOffset = CFrame.new(sideShift, bounce, 0) * CFrame.Angles(pitch, yaw, roll)
		else
			local idleWave = math.sin(elapsed * 2.4)
			local bob = idleWave * 0.06
			local roll = math.rad(2) * idleWave

			animationOffset = CFrame.new(0, bob, 0) * CFrame.Angles(0, 0, roll)
		end

		motionWeld.C0 = baseOffset * animationOffset
	end)
end

local function collectCharacterWeldTargets(character)
	local targets = {}

	for _, descendant in character:GetDescendants() do
		if descendant:IsA("BasePart") and not isBrainrotAppliedInstance(descendant) then
			table.insert(targets, descendant)
		end
	end

	return targets
end

local function findClosestWeldTarget(part, targets, fallback)
	local closestTarget = fallback
	local closestDistance = math.huge

	for _, target in ipairs(targets) do
		local distance = (target.Position - part.Position).Magnitude
		if distance < closestDistance then
			closestDistance = distance
			closestTarget = target
		end
	end

	return closestTarget or fallback
end

local function findCharacterPartByNames(character, names)
	for _, name in ipairs(names) do
		local part = character:FindFirstChild(name, true)
		if part and part:IsA("BasePart") then
			return part
		end
	end

	return nil
end

local function findNamedVisualAnchor(instance, visualModel)
	local current = instance

	while current and current ~= visualModel do
		local lowerName = string.lower(current.Name)
		if lowerName == "leftshoe" or lowerName == "rightshoe" or lowerName == "middleshoe" or lowerName == "body" then
			return lowerName
		end

		current = current.Parent
	end

	return nil
end

local function resolveRigidVisualTarget(character, fallback, config)
	local preferredTargetNames = config and config.rigidVisualTargetNames
	if preferredTargetNames then
		local preferredTarget = findCharacterPartByNames(character, preferredTargetNames)
		if preferredTarget then
			return preferredTarget
		end
	end

	return findCharacterPartByNames(character, { "UpperTorso", "Torso", "LowerTorso", "HumanoidRootPart" }) or fallback
end

local function findPreferredWeldTarget(character, part, visualModel, closestTargets, fallback, config)
	local anchorName = findNamedVisualAnchor(part, visualModel)
	local rigidTarget = resolveRigidVisualTarget(character, fallback, config)

	if config and config.rigidVisual then
		return rigidTarget
	end

	if anchorName == "leftshoe" then
		return findCharacterPartByNames(character, { "LeftFoot", "LeftLowerLeg", "LeftUpperLeg", "Left Leg" }) or fallback
	end

	if anchorName == "rightshoe" then
		return findCharacterPartByNames(character, { "RightFoot", "RightLowerLeg", "RightUpperLeg", "Right Leg" }) or fallback
	end

	if anchorName == "middleshoe" then
		return findCharacterPartByNames(character, { "LowerTorso", "UpperTorso", "Torso", "HumanoidRootPart" }) or fallback
	end

	if anchorName == "body" then
		return findCharacterPartByNames(character, { "UpperTorso", "Torso", "LowerTorso", "HumanoidRootPart" }) or fallback
	end

	return findClosestWeldTarget(part, closestTargets, fallback)
end

local function hasNonAccessoryGeometry(asset)
	if asset:IsA("BasePart") and not asset:FindFirstAncestorWhichIsA("Accessory") then
		return true
	end

	for _, descendant in asset:GetDescendants() do
		if descendant:IsA("BasePart") and not descendant:FindFirstAncestorWhichIsA("Accessory") then
			return true
		end
	end

	return false
end

local function createPreviewBodyPart(parent, name, size, cframe)
	local part = Instance.new("Part")
	part.Name = name
	part.Size = size
	part.CFrame = cframe
	part.Color = Color3.fromRGB(255, 220, 195)
	part.Material = Enum.Material.SmoothPlastic
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	part.CanCollide = false
	part.Anchored = true
	part.Parent = parent
	return part
end

local function addPreviewAttachment(parent, name, position)
	local attachment = Instance.new("Attachment")
	attachment.Name = name
	attachment.Position = position
	attachment.Parent = parent
	return attachment
end

local function createPreviewRig(name)
	local model = Instance.new("Model")
	model.Name = name

	local humanoid = Instance.new("Humanoid")
	humanoid.Name = "Humanoid"
	humanoid.RigType = Enum.HumanoidRigType.R6
	humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
	humanoid.Parent = model

	local rootPart = createPreviewBodyPart(model, "HumanoidRootPart", Vector3.new(2, 2, 1), CFrame.new(0, 3, 0))
	rootPart.Transparency = 1

	local torso = createPreviewBodyPart(model, "Torso", Vector3.new(2, 2, 1), CFrame.new(0, 3, 0))
	local head = createPreviewBodyPart(model, "Head", Vector3.new(2, 1, 1), CFrame.new(0, 4.5, 0))
	local leftArm = createPreviewBodyPart(model, "Left Arm", Vector3.new(1, 2, 1), CFrame.new(-1.5, 3, 0))
	local rightArm = createPreviewBodyPart(model, "Right Arm", Vector3.new(1, 2, 1), CFrame.new(1.5, 3, 0))
	local leftLeg = createPreviewBodyPart(model, "Left Leg", Vector3.new(1, 2, 1), CFrame.new(-0.5, 1, 0))
	local rightLeg = createPreviewBodyPart(model, "Right Leg", Vector3.new(1, 2, 1), CFrame.new(0.5, 1, 0))

	addPreviewAttachment(head, "HatAttachment", Vector3.new(0, 0.5, 0))
	addPreviewAttachment(head, "HairAttachment", Vector3.new(0, 0.5, 0))
	addPreviewAttachment(head, "FaceFrontAttachment", Vector3.new(0, 0, -0.6))
	addPreviewAttachment(head, "FaceCenterAttachment", Vector3.new(0, 0, -0.6))
	addPreviewAttachment(torso, "BodyFrontAttachment", Vector3.new(0, 0, -0.5))
	addPreviewAttachment(torso, "BodyBackAttachment", Vector3.new(0, 0, 0.5))
	addPreviewAttachment(torso, "NeckAttachment", Vector3.new(0, 1, 0))
	addPreviewAttachment(torso, "WaistFrontAttachment", Vector3.new(0, -1, -0.5))
	addPreviewAttachment(torso, "WaistBackAttachment", Vector3.new(0, -1, 0.5))
	addPreviewAttachment(leftArm, "LeftShoulderAttachment", Vector3.new(0, 1, 0))
	addPreviewAttachment(rightArm, "RightShoulderAttachment", Vector3.new(0, 1, 0))
	addPreviewAttachment(leftLeg, "LeftFootAttachment", Vector3.new(0, -1, 0))
	addPreviewAttachment(rightLeg, "RightFootAttachment", Vector3.new(0, -1, 0))

	local face = Instance.new("Decal")
	face.Name = "face"
	face.Texture = "rbxasset://textures/face.png"
	face.Parent = head

	model.PrimaryPart = rootPart
	return model
end

local function buildPreviewAsset(asset, previewName, config)
	if hasNonAccessoryGeometry(asset) then
		local previewClone = buildVisualModel(asset)
		previewClone.Name = previewName
		scaleModelIfNeeded(previewClone, resolveAssetScale(asset, config))
		if config and config.assetOffset then
			pcall(function()
				previewClone:PivotTo(config.assetOffset.Rotation)
			end)
		end
		applyConfiguredPartOffsets(previewClone, config and config.partOffsets or nil)
		return previewClone
	end

	local previewRig = createPreviewRig(previewName)
	local wearablesFound = applyWearablesToModel(previewRig, asset, false)
	stripScripts(previewRig)
	scaleModelIfNeeded(previewRig, resolveAssetScale(asset, config))

	if wearablesFound then
		return previewRig
	end

	return nil
end

local function syncPreviewAssets()
	for _, child in brainrotPreviewFolder:GetChildren() do
		child:Destroy()
	end

	for brainrotId, config in BRAINROTS do
		local asset = brainrotAssetsFolder:FindFirstChild(config.assetName)
		if asset then
			local previewClone = buildPreviewAsset(asset, brainrotId, config)
			if previewClone then
				previewClone.Parent = brainrotPreviewFolder
			end
		end
	end
end

local function queuePreviewSync()
	if previewSyncQueued then
		return
	end

	previewSyncQueued = true
	task.defer(function()
		previewSyncQueued = false
		resolvedAssetScales = {}
		syncPreviewAssets()
	end)
end

local function applyVisualModel(character, asset, config)
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then
		return
	end

	local weldTargets = collectCharacterWeldTargets(character)
	local visualModel = buildVisualModel(asset)
	visualModel.Name = "BrainrotVisuals"
	scaleModelIfNeeded(visualModel, resolveAssetScale(asset, config))

	if not visualModel.PrimaryPart then
		local primaryPart = visualModel:FindFirstChildWhichIsA("BasePart", true)
		if primaryPart then
			visualModel.PrimaryPart = primaryPart
		end
	end

	if visualModel.PrimaryPart then
		visualModel:PivotTo(rootPart.CFrame * (config.assetOffset or CFrame.new()))
	end

	applyConfiguredPartOffsets(visualModel, config.partOffsets)

	visualModel.Parent = character

	for _, descendant in visualModel:GetDescendants() do
		if descendant:IsA("BasePart") then
			descendant.CanCollide = false
			descendant.CanTouch = false
			configureBrainrotQueryPart(descendant)
			descendant.Massless = true
			descendant.Anchored = false
			descendant.CastShadow = false

			local weldTarget = findPreferredWeldTarget(character, descendant, visualModel, weldTargets, rootPart, config)
			local weld = Instance.new("WeldConstraint")
			weld.Part0 = weldTarget
			weld.Part1 = descendant
			weld.Parent = descendant
		end
	end

	hideBaseCharacter(character, true)
end

local function applyAnimatedVisualModel(character, asset, config)
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then
		return
	end

	local baseOffset = config.assetOffset or CFrame.new()
	local motionRoot, motionWeld = createVisualMotionRoot(character, rootPart, baseOffset)
	local visualModel = buildVisualModel(asset)
	visualModel.Name = "BrainrotVisuals"
	scaleModelIfNeeded(visualModel, resolveAssetScale(asset, config))

	if not visualModel.PrimaryPart then
		local primaryPart = visualModel:FindFirstChildWhichIsA("BasePart", true)
		if primaryPart then
			visualModel.PrimaryPart = primaryPart
		end
	end

	if visualModel.PrimaryPart then
		visualModel:PivotTo(motionRoot.CFrame)
	end

	applyConfiguredPartOffsets(visualModel, config.partOffsets)
	visualModel.Parent = character

	for _, descendant in visualModel:GetDescendants() do
		if descendant:IsA("BasePart") then
			descendant.CanCollide = false
			descendant.CanTouch = false
			configureBrainrotQueryPart(descendant)
			descendant.Massless = true
			descendant.Anchored = false
			descendant.CastShadow = false

			local weld = Instance.new("WeldConstraint")
			weld.Part0 = motionRoot
			weld.Part1 = descendant
			weld.Parent = descendant
		end
	end

	startVisualMotion(character, rootPart, motionWeld, config)
	hideBaseCharacter(character, true)
end

