local function getSelectedBrainrotId(player)
	local brainrotId = selectedBrainrots[player]
	if brainrotId and not BRAINROTS[brainrotId] then
		selectedBrainrots[player] = nil
		brainrotId = nil
	end
	return brainrotId
end

local function getActiveBrainrotId(player)
	local brainrotId = activeRoundBrainrots[player]
	if brainrotId and not BRAINROTS[brainrotId] then
		activeRoundBrainrots[player] = nil
		brainrotId = nil
	end
	return brainrotId
end

local function getEffectiveBrainrotId(player)
	return getActiveBrainrotId(player) or getSelectedBrainrotId(player)
end

local function buildBrainrotOptions(player)
	local options = {}

	for id, config in BRAINROTS do
		table.insert(options, {
			id = id,
			displayName = config.displayName,
			description = t(player, config.descriptionKey),
			bonusText = t(player, config.bonusKey),
			uiColor = config.uiColor,
			order = config.order,
		})
	end

	table.sort(options, function(left, right)
		return left.order < right.order
	end)

	return options
end

local function sendBrainrotState(player, messageKey, messageParams)
	local brainrotId = getEffectiveBrainrotId(player)
	local config = brainrotId and BRAINROTS[brainrotId] or nil

	BrainrotEvent:FireClient(player, "sync", {
		options = buildBrainrotOptions(player),
		selectedId = brainrotId,
		selectedName = config and config.displayName or t(player, "common.random"),
		hasSelection = brainrotId ~= nil,
		locked = roundActive,
		message = messageKey and t(player, messageKey, messageParams) or "",
	})
end

local function syncBrainrotStateForAll(messageKey, messageParams)
	for _, player in Players:GetPlayers() do
		sendBrainrotState(player, messageKey, messageParams)
	end
end

