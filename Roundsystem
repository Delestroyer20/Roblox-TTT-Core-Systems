Players.PlayerRemoving:Connect(function(player)
	if characterConnections[player] then
		characterConnections[player]:Disconnect()
		characterConnections[player] = nil
	end

	if player.Character then
		disconnectCharacterCombatEffects(player.Character)
		disconnectVisualAnimation(player.Character)
	end

	selectedBrainrots[player] = nil
	activeRoundBrainrots[player] = nil
	playerRoles[player] = nil
	deadPlayers[player] = nil
end)

for _, player in Players:GetPlayers() do
	setupPlayer(player)
end

local function assignRoles()
	local allPlayers = Players:GetPlayers()
	playerRoles = {}

	for _, player in ipairs(allPlayers) do
		playerRoles[player] = "Innocent"
	end

	local traitorCount, detectiveCount = getRoleDistribution(#allPlayers)

	local shuffled = {}
	for _, player in ipairs(allPlayers) do
		table.insert(shuffled, player)
	end

	for index = #shuffled, 2, -1 do
		local swapIndex = math.random(1, index)
		shuffled[index], shuffled[swapIndex] = shuffled[swapIndex], shuffled[index]
	end

	for index = 1, traitorCount do
		playerRoles[shuffled[index]] = "Traitor"
	end

	local innocentCandidates = {}
	for _, player in ipairs(shuffled) do
		if playerRoles[player] == "Innocent" then
			table.insert(innocentCandidates, player)
		end
	end

	local assignedDetectiveCount = math.min(detectiveCount, #innocentCandidates)
	for index = 1, assignedDetectiveCount do
		playerRoles[innocentCandidates[index]] = "Detective"
	end

	for _, player in ipairs(allPlayers) do
		local role = playerRoles[player]
		local traitorNames = {}
		local brainrotId = getEffectiveBrainrotId(player)
		local brainrotConfig = brainrotId and BRAINROTS[brainrotId] or nil
		local team = if role == "Traitor" then "Traitor" else "Innocent"

		if role == "Traitor" then
			for otherPlayer, otherRole in playerRoles do
				if otherRole == "Traitor" and otherPlayer ~= player then
					table.insert(traitorNames, otherPlayer.Name)
				end
			end
		end

		player:SetAttribute("TTTRole", role)
		player:SetAttribute("TTTRoleTeam", team)

		RoundEvent:FireClient(player, "roleAssigned", {
			role = role,
			team = team,
			traitorAllies = traitorNames,
			brainrotId = brainrotId,
			brainrotName = brainrotConfig and brainrotConfig.displayName or t(player, "common.random"),
		})
	end
end

local function checkWinCondition()
	if not roundActive then
		return
	end

	local aliveTraitors = 0
	local aliveInnocents = 0

	for player, role in playerRoles do
		if not deadPlayers[player] then
			if role == "Traitor" then
				aliveTraitors += 1
			else
				aliveInnocents += 1
			end
		end
	end

	if aliveTraitors == 0 then
		roundWinner = "Innocent"
		endRound()
	elseif aliveInnocents == 0 then
		roundWinner = "Traitor"
		endRound()
	end
end

local function onPlayerDied(player)
	local character = player.Character
	if not character then
		return
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return
	end

	local connection
	connection = humanoid.Died:Connect(function()
		deadPlayers[player] = true
		preserveCorpse(player, character)
		checkWinCondition()
	end)

	table.insert(deathConnections, connection)
end

local function cleanupDeathConnections()
	for _, connection in deathConnections do
		if connection then
			connection:Disconnect()
		end
	end

	deathConnections = {}
end

getRoleDistribution = function(playerCount)
	local cappedPlayerCount = math.min(playerCount, MAX_PLAYERS)

	if cappedPlayerCount >= 7 then
		return 2, 1
	end

	if cappedPlayerCount >= MIN_PLAYERS then
		return 1, 1
	end

	return 0, 0
end

local function getRequiredPlayerCount()
	if ALLOW_SOLO_ROUND_START then
		return 1
	end

	return MIN_PLAYERS
end

local function getRoundPlayerGateState()
	local playerCount = #Players:GetPlayers()
	local requiredPlayerCount = getRequiredPlayerCount()

	if playerCount < requiredPlayerCount then
		return "round.waitingForPlayers", {
			playerCount = playerCount,
			minPlayers = requiredPlayerCount,
		}
	end

	if playerCount > MAX_PLAYERS then
		return "round.tooManyPlayers", {
			playerCount = playerCount,
			maxPlayers = MAX_PLAYERS,
		}
	end

	return nil
end

local function intermission()
	local countdownId = beginNewCountdown()
	roundActive = false
	roundWinner = ""
	activeRoundBrainrots = {}

	for _, player in Players:GetPlayers() do
		clearStandaloneTools(player)
	end

	syncBrainrotStateForAll("brainrot.messages.chooseForNextRound")

	while true do
		local gateMessageKey, gateMessageParams = getRoundPlayerGateState()
		if not gateMessageKey then
			break
		end

		if countdownId ~= countdownToken then
			return false
		end

		broadcastLocalized("waiting", {
			timeLeft = 0,
		}, gateMessageKey, gateMessageParams)

		task.wait(2)
	end

	for timeLeft = INTERMISSION_TIME, 1, -1 do
		if countdownId ~= countdownToken then
			return false
		end

		local gateMessageKey = getRoundPlayerGateState()
		if gateMessageKey then
			return false
		end

		broadcastLocalized("intermission", {
			timeLeft = timeLeft,
		}, "round.nextRoundIn")

		task.wait(1)
	end

	return true
end

local function startRound()
	local gateMessageKey = getRoundPlayerGateState()
	if gateMessageKey then
		return
	end

	local countdownId = beginNewCountdown()
	roundActive = true
	roundWinner = ""
	cleanupDeathConnections()
	cleanupSpawnedCorpses()

	activeRoundBrainrots = {}
	for _, player in Players:GetPlayers() do
		activeRoundBrainrots[player] = getSelectedBrainrotId(player) or getRandomBrainrotId()
	end

	syncBrainrotStateForAll("brainrot.messages.roundStarting")

	for _, player in Players:GetPlayers() do
		player:LoadCharacter()
	end

	task.wait(1)

	if not roundActive or countdownId ~= countdownToken then
		return
	end

	assignRoles()
	deadPlayers = {}

	for _, player in Players:GetPlayers() do
		applyBrainrotLoadout(player)
		onPlayerDied(player)
	end

	broadcastLocalized("roundStart", nil, "round.started")

	if isSoloReturnTest() then
		for timeLeft = DEBUG_SOLO_ROUND_TIME, 1, -1 do
			if not roundActive or countdownId ~= countdownToken then
				break
			end

			broadcastLocalized("roundActive", {
				timeLeft = timeLeft,
			}, "round.inProgress")

			task.wait(1)
		end

		if roundActive and countdownId == countdownToken then
			roundWinner = "Innocent"
			endRound()
		end

		return
	end

	for timeLeft = ROUND_TIME, 1, -1 do
		if not roundActive or countdownId ~= countdownToken then
			break
		end

		broadcastLocalized("roundActive", {
			timeLeft = timeLeft,
		}, "round.inProgress")

		task.wait(1)
	end

	if roundActive and countdownId == countdownToken then
		roundWinner = "Innocent"
		endRound()
	end
end

function endRound()
	if not roundActive then
		return
	end

	roundActive = false
	countdownToken += 1

	cleanupDeathConnections()

	broadcastLocalized("roundEnd", {
		timeLeft = 0,
		winner = roundWinner,
	}, roundWinner == "Innocent" and "round.ending.innocentsWin" or "round.ending.traitorsWin")
end

while true do
	local intermissionFinished = intermission()
	if intermissionFinished then
		startRound()

		task.wait(POST_ROUND_RETURN_DELAY)

		local returnedPlayersToLobby = returnPlayersToLobby()
		if returnedPlayersToLobby then
			task.wait(2)
		else
			playerRoles = {}
			deadPlayers = {}
			cleanupSpawnedCorpses()

			for _, player in Players:GetPlayers() do
				player:SetAttribute("TTTRole", nil)
				player:SetAttribute("TTTRoleTeam", nil)
				player:LoadCharacter()
			end
		end
	else
		task.wait(1)
	end
end
