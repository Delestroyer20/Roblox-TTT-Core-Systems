local function resolveWeaponFireOrigin(character, clientOrigin)
	local head = character and character:FindFirstChild("Head")
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	local fallback = (head and head.Position) or (rootPart and rootPart.Position)
	if not fallback then
		return nil
	end

	if typeof(clientOrigin) ~= "Vector3" then
		return fallback
	end

	local headDistance = head and (clientOrigin - head.Position).Magnitude or math.huge
	local rootDistance = rootPart and (clientOrigin - rootPart.Position).Magnitude or math.huge
	if math.min(headDistance, rootDistance) <= MAX_CLIENT_FIRE_ORIGIN_DISTANCE then
		return clientOrigin
	end

	return fallback
end

local function shouldIgnoreRaycastPassthroughPart(instance)
	if not instance or instance:IsA("Terrain") or instance.Name == "Baseplate" then
		return false
	end

	if findHumanoidFromInstance(instance) then
		return false
	end

	if instance:FindFirstAncestorWhichIsA("Tool") then
		return true
	end

	if instance.Name == "Bullet" or instance.Name == "Shell" or instance.Name == "HitboxTesterMarker" then
		return true
	end

	if instance:IsA("BasePart") and instance.Transparency >= 0.95 then
		return true
	end

	return false
end

local function raycastWeapon(definition, character, origin, direction)
	local bulletsFolder = getBulletsFolder()
	local filterInstances = { character }
	if bulletsFolder then
		table.insert(filterInstances, bulletsFolder)
	end

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.IgnoreWater = true

	local unitDirection = direction.Unit
	local maxPasses = 8
	local currentOrigin = origin
	local remainingRange = definition.range
	local lastResult = nil

	for _ = 1, maxPasses do
		rayParams.FilterDescendantsInstances = filterInstances

		local result = Workspace:Raycast(currentOrigin, unitDirection * remainingRange, rayParams)
		if not result then
			return nil
		end

		lastResult = result
		if not shouldIgnoreRaycastPassthroughPart(result.Instance) then
			return result
		end

		table.insert(filterInstances, result.Instance)
		local traveled = (result.Position - origin).Magnitude
		remainingRange = definition.range - traveled
		if remainingRange <= 0.05 then
			break
		end

		currentOrigin = result.Position + unitDirection * 0.05
	end

	return lastResult
end

local function handleWeaponFire(player, tool, clientOrigin, direction)
	if not roundActive then
		return
	end

	if typeof(clientOrigin) == "Vector3" and typeof(direction) ~= "Vector3" then
		direction = clientOrigin
		clientOrigin = nil
	end

	if typeof(direction) ~= "Vector3" or direction.Magnitude <= 0.001 then
		return
	end

	if not tool or not tool:IsA("Tool") or tool.Parent ~= player.Character then
		return
	end

	local state = weaponStates[tool]
	if not state or getToolOwner(tool) ~= player then
		return
	end

	local humanoid = getLiveHumanoid(player)
	if not humanoid or state.isReloading then
		return
	end

	local now = os.clock()
	if now - state.lastFireAt < state.definition.fireCooldown then
		return
	end

	if state.ammo <= 0 then
		return
	end

	local character = player.Character
	local origin = resolveWeaponFireOrigin(character, clientOrigin)
	if not origin then
		return
	end

	state.lastFireAt = now
	state.ammo -= 1
	syncWeaponAttributes(tool, state)

	local result = raycastWeapon(state.definition, character, origin, direction)
	if not result then
		if state.definition.weaponId == "hitbox_tester" then
			createHitboxDebugMarker(origin + direction.Unit * math.min(state.definition.range, 80), Color3.fromRGB(255, 80, 80))
		end
		return
	end

	local targetHumanoid = findHumanoidFromInstance(result.Instance)
	if not targetHumanoid or targetHumanoid == humanoid or targetHumanoid.Health <= 0 then
		if state.definition.weaponId == "hitbox_tester" then
			createHitboxDebugMarker(result.Position, Color3.fromRGB(255, 175, 35))
		end
		return
	end

	local targetCharacter = targetHumanoid.Parent
	if targetCharacter == character then
		if state.definition.weaponId == "hitbox_tester" then
			createHitboxDebugMarker(result.Position, Color3.fromRGB(255, 80, 80))
		end
		return
	end

	tagHumanoidKiller(targetHumanoid, player)
	targetHumanoid:TakeDamage(state.definition.damage)
	if state.definition.weaponId == "hitbox_tester" then
		createHitboxDebugMarker(result.Position, Color3.fromRGB(70, 255, 120))
	end
end

