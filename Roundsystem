local function ensureHealthRegenOverrideScript()
	if not DISABLE_DEFAULT_HEALTH_REGEN then
		return
	end

	local starterCharacterScripts = StarterPlayer:FindFirstChild("StarterCharacterScripts")
	if not starterCharacterScripts then
		return
	end

	local healthScript = starterCharacterScripts:FindFirstChild("Health")
	if healthScript and not healthScript:IsA("Script") then
		healthScript:Destroy()
		healthScript = nil
	end

	if not healthScript then
		healthScript = Instance.new("Script")
		healthScript.Name = "Health"
		healthScript.Parent = starterCharacterScripts
	end

	healthScript:SetAttribute("TTTDisableDefaultRegen", true)
end

local function disconnectCharacterCombatEffects(character)
	local connections = characterCombatConnections[character]
	if connections then
		for _, connection in ipairs(connections) do
			connection:Disconnect()
		end

		characterCombatConnections[character] = nil
	end

	damageFlashTokens[character] = nil

	local existingFlash = character and character:FindFirstChild("TTTDamageFlash")
	if existingFlash then
		existingFlash:Destroy()
	end
end

local function getDamageFlashAdornee(character)
	for _, child in ipairs(character:GetChildren()) do
		if child:GetAttribute("BrainrotApplied") and child:IsA("Model") then
			return child
		end
	end

	for _, child in ipairs(character:GetChildren()) do
		if child:GetAttribute("BrainrotApplied") and child:IsA("BasePart") then
			return child
		end
	end

	return character
end

local function flashCharacterDamage(character)
	if not character or character.Parent == nil then
		return
	end

	local token = (damageFlashTokens[character] or 0) + 1
	damageFlashTokens[character] = token

	local existingFlash = character:FindFirstChild("TTTDamageFlash")
	if existingFlash then
		existingFlash:Destroy()
	end

	local highlight = Instance.new("Highlight")
	highlight.Name = "TTTDamageFlash"
	highlight.Adornee = getDamageFlashAdornee(character)
	highlight.DepthMode = Enum.HighlightDepthMode.Occluded
	highlight.FillColor = Color3.fromRGB(255, 70, 70)
	highlight.FillTransparency = 0.28
	highlight.OutlineColor = Color3.fromRGB(255, 120, 120)
	highlight.OutlineTransparency = 0.65
	highlight.Parent = character

	Debris:AddItem(highlight, DAMAGE_FLASH_DURATION + 0.05)

	task.delay(DAMAGE_FLASH_DURATION, function()
		if damageFlashTokens[character] ~= token then
			return
		end

		if highlight.Parent then
			highlight:Destroy()
		end
	end)
end

local function attachCharacterCombatEffects(character)
	disconnectCharacterCombatEffects(character)

	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return
	end

	local previousHealth = humanoid.Health
	local connections = {}

	local function removeDefaultHealthScript(scriptInstance)
		if not DISABLE_DEFAULT_HEALTH_REGEN then
			return
		end

		if not scriptInstance or not scriptInstance:IsA("Script") or scriptInstance.Name ~= "Health" then
			return
		end

		if scriptInstance:GetAttribute("TTTDisableDefaultRegen") then
			return
		end

		if pendingHealthScriptRemovals[scriptInstance] then
			return
		end

		pendingHealthScriptRemovals[scriptInstance] = true
		task.defer(function()
			if scriptInstance and scriptInstance.Parent and not scriptInstance:GetAttribute("TTTDisableDefaultRegen") then
				scriptInstance.Disabled = true
				scriptInstance:SetAttribute("TTTDisableDefaultRegen", true)
			end

			pendingHealthScriptRemovals[scriptInstance] = nil
		end)
	end

	removeDefaultHealthScript(character:FindFirstChild("Health"))
	task.spawn(function()
		for _ = 1, 20 do
			if not character.Parent then
				break
			end

			local healthScript = character:FindFirstChild("Health")
			if healthScript then
				removeDefaultHealthScript(healthScript)
				if healthScript:GetAttribute("TTTDisableDefaultRegen") or healthScript.Disabled then
					break
				end
			end

			task.wait(0.25)
		end
	end)
	table.insert(connections, humanoid.HealthChanged:Connect(function(currentHealth)
		if currentHealth < previousHealth - 0.05 then
			flashCharacterDamage(character)
		end

		previousHealth = currentHealth
	end))
	table.insert(connections, character.AncestryChanged:Connect(function(_, parent)
		if parent == nil then
			disconnectCharacterCombatEffects(character)
		end
	end))

	characterCombatConnections[character] = connections
end

