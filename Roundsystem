local function applyBrainrotLook(player, character)
	clearBrainrotVisuals(character)
	hideBaseCharacter(character, false)

	local brainrotId = getEffectiveBrainrotId(player)
	if not brainrotId then
		return
	end

	local config = BRAINROTS[brainrotId]
	local asset = brainrotAssetsFolder:FindFirstChild(config.assetName)
	if not asset then
		return
	end

	if config.visualMotionStyle and hasNonAccessoryGeometry(asset) then
		applyAnimatedVisualModel(character, asset, config)
		createBrainrotHitboxes(character, brainrotId)
		return
	end

	local wearablesFound = cloneWearables(character, asset)
	if not wearablesFound then
		applyVisualModel(character, asset, config)
	end

	createBrainrotHitboxes(character, brainrotId)
end

local function applyBrainrotLoadout(player)
	local character = player.Character
	if not character then
		return
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local brainrotId = getEffectiveBrainrotId(player)
	local config = brainrotId and BRAINROTS[brainrotId] or nil

	if humanoid then
		humanoid.BreakJointsOnDeath = not roundActive
		humanoid.WalkSpeed = config and config.walkSpeed or 16
		humanoid.MaxHealth = config and config.maxHealth or 100
		humanoid.Health = humanoid.MaxHealth

		if humanoid.UseJumpPower then
			humanoid.JumpPower = config and config.jumpPower or 50
		else
			humanoid.JumpHeight = config and config.jumpHeight or 7.2
		end
	end

	applyBrainrotLook(player, character)
	clearGrantedTools(player)

	if not roundActive or not config then
		clearStandaloneTools(player)
		return
	end

	for _, toolName in ipairs(config.kit) do
		giveToolIfExists(player, toolName)
	end

	if DEFAULT_SIDEARM_ENABLED then
		giveToolIfExists(player, DEFAULT_SIDEARM_TOOL_NAME)
	end
	if DEBUG_HITSCAN_TEST_WEAPON_ENABLED then
		giveToolIfExists(player, DEBUG_HITSCAN_TOOL_NAME)
	end

	if playerRoles[player] == "Traitor" then
		for _, toolName in ipairs(config.traitorKit) do
			giveToolIfExists(player, toolName)
		end
	end
end

local function onCharacterAdded(player, character)
	task.defer(function()
		character:WaitForChild("Humanoid", 5)
		character:WaitForChild("HumanoidRootPart", 5)
		attachCharacterCombatEffects(character)
		applyBrainrotLoadout(player)
	end)
end

local function setupPlayer(player)
	selectedBrainrots[player] = getSelectedBrainrotId(player)
	activeRoundBrainrots[player] = nil
	player:SetAttribute("SelectedBrainrot", selectedBrainrots[player])
	player:SetAttribute("TTTRole", nil)
	player:SetAttribute("TTTRoleTeam", nil)

	if characterConnections[player] then
		characterConnections[player]:Disconnect()
	end

	characterConnections[player] = player.CharacterAdded:Connect(function(character)
		onCharacterAdded(player, character)
	end)

	sendBrainrotState(player)

	if not roundActive then
		task.defer(function()
			if player.Parent == Players then
				player:LoadCharacter()
			end
		end)
	elseif player.Character then
		onCharacterAdded(player, player.Character)
	end
end

RoundEvent.OnServerEvent:Connect(function(player, action)
	if not DEBUG_KILL_BUTTON_ENABLED then
		return
	end

	if action ~= "debugKill" then
		return
	end

	local character = player.Character
	if not character then
		return
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid or humanoid.Health <= 0 then
		return
	end

	humanoid.Health = 0
end)

WeaponRemote.OnServerEvent:Connect(function(player, action, tool, origin, direction)
	if action == "fire" then
		handleWeaponFire(player, tool, origin, direction)
		return
	end

	if action ~= "reload" then
		return
	end

	if not roundActive then
		return
	end

	if not tool or not tool:IsA("Tool") or tool.Parent ~= player.Character then
		return
	end

	local state = weaponStates[tool]
	if not state or getToolOwner(tool) ~= player then
		return
	end

	if not getLiveHumanoid(player) then
		return
	end

	beginWeaponReload(player, tool, state)
end)

BrainrotEvent.OnServerEvent:Connect(function(player, action, brainrotId)
	if action == "requestBrainrotData" then
		sendBrainrotState(player)
		return
	end

	if action ~= "selectBrainrot" then
		return
	end

	if roundActive then
		sendBrainrotState(player, "brainrot.messages.selectionLockedDuringRound")
		return
	end

	if not BRAINROTS[brainrotId] then
		sendBrainrotState(player, "brainrot.messages.unknown")
		return
	end

	selectedBrainrots[player] = brainrotId
	player:SetAttribute("SelectedBrainrot", brainrotId)

	if player.Character then
		applyBrainrotLoadout(player)
	end

	sendBrainrotState(player, "brainrot.messages.selected", {
		name = BRAINROTS[brainrotId].displayName,
	})
end)

